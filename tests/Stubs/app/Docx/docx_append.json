{
    "title": "文档管理",
    "module": "core",
    "table_name": "docx_append",
    "fields": [
        {"name": "table_name", "type": "text", "label": "表名称", "length": 50, "is_required": 1, "is_unique": 1,
            "is_edit": 0
        },
        {"name": "parent_table_name", "type": "link", "label": "关联表", "is_edit": 0, "extends":  {
            "name": "docx_append",
            "value": "table_name",
            "label": "title",
            "filter": []
        }},
        {"name": "quick_entry", "type": "radio", "label": "测试单选", "options": [
            {"label": "是", "value": 1},
            {"label": "否", "value": 0}
        ], "default":  0},
        {"name": "read_only", "type": "checkbox", "label": "测试多选", "options": [
            {"label": "是", "value": 1},
            {"label": "否", "value": 2},
            {"label": "123", "value": 3},
            {"label": "wer", "value": 4}
        ], "default":  1},
        {"name": "is_publish", "type": "select", "label": "测试下拉", "options": [
            {"label": "是", "value": 1},
            {"label": "否", "value": 0}
        ], "default":  0},
        {"name": "is_single", "type": "select", "label": "测试下拉多选", "options": [
            {"label": "是", "value": 1},
            {"label": "否", "value": 0}
        ], "default":  0},
        {"name": "allow_rename", "type": "radio", "label": "测试来源为textarea", "options": [
            {"label": "是", "value": 1},
            {"label": "否", "value": 0}
        ], "default":  0, "extends":  {
            "type": "textarea",
            "content": "aa=d",
            "intro": "这个配置来源与laravel的系统配置信息，配置个格式与options一致"
        }},
        {"name": "status", "type": "radio", "label": "测试来源为配置", "options": [
            {"label": "已启用", "value": 1, "color": "#ccc"},
            {"label": "未启用", "value": 0, "color": "#ccc"}
        ], "default":  0, "extends":  {
            "type": "config",
            "key": "constant.status",
            "intro": "这个配置来源与laravel的系统配置信息，配置个格式与options一致"
        }}
    ]
}
